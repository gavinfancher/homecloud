# Clerk publishable key (public). Pull the real value with `clerk env pull`,
# which writes it to .env.local (gitignored).
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Base URL of the controller API. Leave empty in dev (the Vite proxy in
# vite.config.ts forwards /api and /auth to http://localhost:8080).
# In production set to the tunnel host, e.g. https://api.myhomecloud.dev
VITE_API_BASE=

# Local-dev auth bypass. When "true", the SPA skips Clerk (no sign-in screen)
# and runs the console with a no-op token. ONLY honored under `vite dev`
# (import.meta.env.DEV) — it can never affect a production build.
# Do NOT set this in Cloudflare Pages production environment variables.
VITE_DEV_BYPASS_AUTH=false
