# Production build config for the SPA (non-secret).
# Clerk publishable key: Cloudflare build env or `clerk env pull` locally.
VITE_API_BASE=https://api.myhomecloud.dev

# Custom domain (app.myhomecloud.dev) — satellite mode + Accounts sign-in URL.
# Also add app.myhomecloud.dev as a satellite domain in Clerk Dashboard → Domains.
VITE_CLERK_IS_SATELLITE=true
VITE_CLERK_DOMAIN=app.myhomecloud.dev
VITE_CLERK_SIGN_IN_URL=https://topical-lemur-74.accounts.dev/sign-in
VITE_CLERK_SIGN_UP_URL=https://topical-lemur-74.accounts.dev/sign-up
